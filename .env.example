# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit real credentials.

# ─── Cloudinary (hosts snapshots + GIFs for Paper to fetch) ───
# Get the combined URL from https://console.cloudinary.com/console
# Dashboard → Account → "API environment variable"
# Format: cloudinary://{api_key}:{api_secret}@{cloud_name}
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# Alternative: set the three components individually instead of the combined URL.
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# ─── Browserbase (cloud Chromium for Stage 9 capture) ───
# Get both from https://www.browserbase.com/settings (Project tab → API Keys)
# Both are required: the API key authenticates, the project ID scopes the session quota.
BROWSERBASE_API_KEY=bb_...
BROWSERBASE_PROJECT_ID=
